        "jsCode": "const items = $input.all();\n\n// 1. Direct Reference: Get the deadline string\nconst deadlineStr = $('External execution').first().json.deadline; \n\n// 2. Helper to format for MySQL (YYYY-MM-DD HH:mm:ss)\nconst toMysqlFormat = (dateInput) => {\n    const date = new Date(dateInput);\n    const YYYY = date.getFullYear();\n    const MM = String(date.getMonth() + 1).padStart(2, '0');\n    const DD = String(date.getDate()).padStart(2, '0');\n    const HH = String(date.getHours()).padStart(2, '0');\n    const mm = String(date.getMinutes()).padStart(2, '0');\n    const ss = String(date.getSeconds()).padStart(2, '0');\n    return `${YYYY}-${MM}-${DD} ${HH}:${mm}:${ss}`;\n};\n\n// Handle date logic\nlet finalDate;\nif (deadlineStr) {\n    finalDate = toMysqlFormat(deadlineStr);\n} else {\n    const fallbackDate = new Date();\n    fallbackDate.setDate(fallbackDate.getDate() + 33);\n    finalDate = toMysqlFormat(fallbackDate);\n}\n\n// 3. Handle busy string formatting\nlet busyString = \"\";\nif (items.length > 0) {\n    // Map through all items to extract the busy_slot property\n    busyString = items.map(i => i.json.busy_slot).filter(slot => slot).join(', ');\n}\n\n// Return the data in the required JSON format\nreturn [\n  {\n    json: {\n      busy_string: busyString,\n      lastDate: $('External execution').first().json.deadline\n    }\n  }\n];"
