        "jsCode": "// Get your busy list from MySQL\nconst busyList = $json.busy_string || \"\"; \nconst deadlineStr = $input.first().json.lastDate;\nconst now = new Date(); \n// Convert server time to UTC+4 specifically\nconst start = new Date(now.getTime() + (now.getTimezoneOffset() * 60000) + (4 * 3600000));\n\nconst end = new Date(deadlineStr);\n\nlet availableSlots = [];\nlet current = new Date(start);\n\n// 1. Initialization: Set start to the beginning of the NEXT available hour\ncurrent.setMinutes(0, 0, 0, 0);\ncurrent.setHours(current.getHours() + 1);\n\n// 2. Initial logic to handle \"Out of Office\" hours immediately\nif (current.getHours() >= 19) {\n    current.setDate(current.getDate() + 1);\n    current.setHours(9);\n} else if (current.getHours() < 9) {\n    current.setHours(9);\n}\n\n\n// 3. Loop through days until deadline\nwhile (current <= end) {\n    const dayOfWeek = current.getDay(); // 0 = Sunday, 6 = Saturday\n    const currentHour = current.getHours();\n    const isWeekend = (dayOfWeek === 0 || dayOfWeek === 6);\n    \n    const dateStr = current.toISOString().split('T')[0];\n    const timeStr = current.toTimeString().split(' ')[0];\n    const timestamp = `${dateStr} ${timeStr}`;\n\n    let isAllowedTime = false;\n    if (isAllowedTime && !busyList.includes(timestamp)) {\n    // FIX: Only push if the slot time is actually after the moment the workflow started\n    if (new Date(current) > start) {\n        availableSlots.push(timestamp);\n    }\n}\n    if (isWeekend) {\n        // Weekend Rule: Allowed 16:00 - 19:00 (3 blocks)\n        if (currentHour >= 16 && currentHour < 19) {\n            isAllowedTime = true;\n        }\n    } else {\n        // Weekday Rule: Allowed 09:00-14:00 AND 16:00-17:00\n        if ((currentHour >= 9 && currentHour < 14) || (currentHour >= 16 && currentHour < 17)) {\n            isAllowedTime = true;\n        }\n    }\n\n\n    if (isAllowedTime && !busyList.includes(timestamp)) {\n        if (current > start) { \n            availableSlots.push(timestamp);\n        }\n    }\n\n    // Move to next hour\n    current.setHours(current.getHours() + 1);\n    \n    // 5. Day rollover: If past 7 PM, jump to 9 AM the next day\n    if (current.getHours() >= 19) {\n        current.setDate(current.getDate() + 1);\n        current.setHours(9);\n    }\n}\n\nreturn { availableSlots };"
