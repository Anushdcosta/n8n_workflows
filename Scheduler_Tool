      "parameters": {
        "jsCode": "const tasks = $input.all(); \nconst slots = $('JS Slot Maker1').first().json.availableSlots;\n\n// 1. Calculate how many \"slots\" we need vs how many we have\nconst totalRequiredBlocks = tasks.reduce((acc, curr) => acc + (curr.json.complexity >= 4 ? 3 : 1), 0);\n\nconst spreadFactor = Math.floor(slots.length / totalRequiredBlocks);\n\nconsole.log(`DEBUG: Required: ${totalRequiredBlocks}, Available: ${slots.length}, Spread: ${spreadFactor}`);\n\nlet finalSchedule = [];\nlet slotIndex = 0;\n\nfunction addOneHour(dateStr) {\n    const date = new Date(dateStr.replace(' ', 'T'));\n    date.setHours(date.getHours() + 1);\n    const YYYY = date.getFullYear();\n    const MM = String(date.getMonth() + 1).padStart(2, '0');\n    const DD = String(date.getDate()).padStart(2, '0');\n    const HH = String(date.getHours()).padStart(2, '0');\n    return `${YYYY}-${MM}-${DD} ${HH}:00:00`;\n}\n\ntasks.forEach((item) => {\n    const task = item.json;\n\n    if (slotIndex >= slots.length) return;\n\n    // Assign Primary Session\n    const startTime = slots[slotIndex];\n    finalSchedule.push({\n        task_name: task.task || task.task_name,\n        complexity: task.complexity,\n        start_time: startTime,\n        end_time: addOneHour(startTime),\n        status: 'Scheduled'\n    });\n\n    // Move index forward by the spread factor to distribute tasks\n    slotIndex += spreadFactor;\n\n    if (task.complexity >= 4) {\n        if (slotIndex < slots.length) {\n            const secondStartTime = slots[slotIndex];\n            finalSchedule.push({\n                task_name: (task.task || task.task_name) + \" (Continued)\",\n                complexity: task.complexity,\n                start_time: secondStartTime,\n                end_time: addOneHour(secondStartTime),\n                status: 'Scheduled'\n            });\n            slotIndex += spreadFactor;\n        }\n    }\n});\n\nreturn finalSchedule.map(item => ({ json: item }));"
