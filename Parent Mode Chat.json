      "parameters": {
        "jsCode": "// 1. Define the target date (Yesterday)\nconst yesterday = $now.minus({ days: 1 });\nconst targetDateStr = yesterday.toFormat(\"yyyy-MM-dd\");\n\nlet completed = 0;\nlet notcompleted = 0;\nlet missedTask = 0;\nlet tasks = [];\n\nfor (const item of $input.first().json.data) {\n  // 2. Filter for tasks matching yesterday's date\n  if (item.task_date === targetDateStr) {\n    tasks.push(item);\n\n    if (item.is_completed === 1) {\n      completed = completed + 1;\n    } else {\n      const dateTimeString = item.start_time;\n      const dateObject = new Date(dateTimeString.replace(' ', 'T')); \n      const taskHour = dateObject.getHours();\n      \n      // 3. Logic for previous day tasks:\n      // Since it is now \"today,\" any task from \"yesterday\" that \n      // wasn't completed is technically \"Missed.\"\n      missedTask = missedTask + 1;\n    }\n  }\n}\n\nreturn { \n  targetDate: targetDateStr, \n  tasks, \n  completed, \n  notcompleted, \n  missedTask \n};"
      },
