      "parameters": {
        "jsCode": "const todaystask = []\n\nfor (const item of $input.first().json.data) {\n  if (item.task_date === $now.toFormat(\"yyyy-MM-dd\")) {\n    if (item.is_completed === 1) {\n      item.status = \"completed\"\n    } else {\n      const dateTimeString = item.start_time\n      const dateObject = new Date(dateTimeString.replace(' ', 'T')); \n      const hour = dateObject.getHours();\n      const enddateTimeString = item.end_time\n      const enddateObject = new Date(enddateTimeString.replace(' ', 'T')); \n      const endhour = enddateObject.getHours();\n      const datenow = new Date($now);\n      console.log(hour, datenow.getUTCHours() + 4)\n      if ( datenow.getHours() + 4 >= endhour) {\n        item.status = \"Missed Task\"\n      } else if ( datenow.getHours() < hour) {\n        item.status = \"Not completed\"\n      }\n    }\n    todaystask.push(item)\n  }\n}\n\nreturn { todaystask }"
      },
